# Copy to .env and fill in. Do NOT commit the real .env.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=Europe/Istanbul

# API login — validated in-memory (no database), used by the dashboard
PC_API_USERNAME=sezer
PC_API_PASSWORD=change-me

# Turso (libSQL) database — get these from `turso db show` / `turso db tokens create`
TURSO_DATABASE_URL=libsql://<your-db>.turso.io
TURSO_AUTH_TOKEN=<your-token>
