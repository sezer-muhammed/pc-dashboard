[Unit]
Description=Sezer PC Dashboard (Next.js dev, hot reload on code change)
After=network-online.target sezer-pc-backend.service

[Service]
Type=simple
WorkingDirectory=%h/Desktop/sezer-pc-backend/frontend
ExecStart=%h/.local/node/bin/node node_modules/next/dist/bin/next dev
Environment=PATH=%h/.local/node/bin:/usr/local/bin:/usr/bin:/bin
Environment=NODE_ENV=development
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
